# Copy this file to ".env" in the same folder (do not commit .env).
#
# EXPO_PUBLIC_SUPABASE_URL must be the API URL from Project Settings → API → Project URL.
# It looks like: https://xxxxxxxx.supabase.co
# NOT the dashboard link (never use https://supabase.com/dashboard/... here).
#
# EXPO_PUBLIC_SUPABASE_ANON_KEY = publishable key (sb_publishable_…) OR legacy anon JWT (eyJ…)
# from the same API page. NOT the secret / service_role key.
# If you see "Invalid API key", re-copy the key with no spaces, or try the legacy anon JWT.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
